{
  "name": "alpacaly-server",
  "version": "1.0.0",
  "private": true,
  "description": "Server-side Event Engine for Alpacaly Ever After",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "edge:dev": "node --watch src/edge-controller/process.js",
    "edge:start": "node src/edge-controller/process.js",
    "start": "node src/server.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "test:postgres": "node --test --test-concurrency=1 test/postgres-integration.test.js",
    "test:postgres:restore": "node --test --test-concurrency=1 test/postgres-backup-restore.test.js",
    "backup:postgres": "node scripts/postgres-backup.js",
    "check:managed-backups": "node scripts/managed-backup-check.js",
    "evaluate:managed-staging": "node scripts/managed-staging-evaluate.js",
    "hold:postgres-backup": "node scripts/postgres-backup-hold.js",
    "restore:postgres": "node scripts/postgres-restore.js",
    "reconcile:postgres-restore": "node scripts/postgres-reconcile-restore.js",
    "release:postgres-recovery": "node scripts/postgres-release-recovery.js",
    "cleanup:test-backups": "node scripts/cleanup-test-backups.js",
    "migrate:sqlite-to-postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "benchmark:postgres-contention": "node scripts/postgres-contention-baseline.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "mqtt": "^5.14.1",
    "pg": "^8.22.0",
    "pino": "^9.7.0"
  },
  "devDependencies": {
    "aedes": "^0.51.3",
    "supertest": "^7.1.1"
  }
}
