NODE_ENV=development
PORT=3000
LOG_LEVEL=info
MAX_DAILY_FEEDS=100
ENFORCE_FEEDING_WINDOW=false
FEEDING_WINDOW_START=08:00
FEEDING_WINDOW_END=18:00
REQUEST_BODY_LIMIT=16kb
CORS_ORIGIN=*
DATABASE_PATH=./data/alpacaly.sqlite
ENABLE_DEMO_RESET=true
ENABLE_DEVELOPMENT_CONTRIBUTION_SIMULATION=true
ENABLE_DEVELOPMENT_AUTHENTICATION=true
MANAGED_IDENTITY_PROVIDER_CONFIGURED=false
CRITICAL_APPROVAL_LIFETIME_MS=900000
OUTBOX_POLL_INTERVAL_MS=250
OUTBOX_RETRY_DELAY_MS=1000
DEVICE_COMMAND_POLL_INTERVAL_MS=100
DEVICE_COMMAND_RETRY_DELAY_MS=1000
DEVICE_COMMAND_MAXIMUM_ATTEMPTS=3
DEVICE_ACKNOWLEDGEMENT_TIMEOUT_MS=5000
DEVICE_TRANSPORT=in_process
MQTT_ENVIRONMENT=development
MQTT_PROTOCOL_VERSION=5
MQTT_COMMAND_QOS=1
MQTT_BROKER_URL=
MQTT_CLIENT_ID=alpacaly-server
MQTT_CONNECT_TIMEOUT_MS=5000
MQTT_RECONNECT_PERIOD_MS=1000
MQTT_COMMAND_EXPIRY_MS=15000
MQTT_AUTHORITY_LEASE_MS=30000
MQTT_HEARTBEAT_INTERVAL_MS=5000
MQTT_STALE_THRESHOLD_MS=15000
MQTT_OFFLINE_THRESHOLD_MS=30000
MQTT_CLOCK_DRIFT_TOLERANCE_MS=2000
MQTT_DEVELOPMENT_KEYS=true
# Production MQTT requires mqtts://, all three TLS paths, an Ed25519 server
# private key, and controller public-key records. Never put production private
# credentials in this example file.
MQTT_TLS_CA_PATH=
MQTT_TLS_CERTIFICATE_PATH=
MQTT_TLS_PRIVATE_KEY_PATH=
MQTT_SERVER_SIGNING_KEY_ID=alpacaly-development-server-2026-01
MQTT_SERVER_SIGNING_PRIVATE_KEY=
MQTT_SERVER_SIGNING_PUBLIC_KEYS={}
MQTT_CONTROLLER_SIGNING_KEY_ID=alpacaly-development-controller-2026-01
MQTT_CONTROLLER_SIGNING_PRIVATE_KEY=
MQTT_CONTROLLER_SIGNING_PUBLIC_KEYS={}
SIMULATED_CONTROLLER_HEARTBEAT_INTERVAL_MS=5000
SIMULATED_CONTROLLER_HEARTBEAT_TIMEOUT_MS=15000
ENABLE_SIMULATED_CONTROLLER_CONFIGURATION=true
EDGE_CALIBRATION_VERSION=simulated-calibration-v1
EDGE_WELFARE_CONFIGURATION_VERSION=edge-welfare-v1
# The separate edge process uses its own SQLite file and fixed resource identity.
EDGE_MODE=development
EDGE_CONTROLLER_ID=controller_simulated_default_barn
EDGE_BARN_ID=barn_00000000-0000-4000-8000-000000000001
EDGE_BARN_TIMEZONE=Europe/London
EDGE_FEEDER_IDS=feeder_00000000-0000-4000-8000-000000000002
EDGE_DATABASE_PATH=./data/barn-edge.sqlite
EDGE_SIMULATED_HARDWARE=true
EDGE_DEVELOPMENT_IDENTITY=true
EDGE_BOOTSTRAP_SIMULATED_FIXTURES=false
EDGE_MQTT_CLIENT_ID=alpacaly-barn-edge-development
EDGE_BELL_DURATION_MS=3000
EDGE_COUNTDOWN_DURATION_MS=10000
EDGE_WATCHDOG_PULSE_MS=100
EDGE_MAINTENANCE_MAXIMUM_JOG_MS=500
EDGE_BELL_FAILURE_POLICY=CANCEL
LIFECYCLE_COUNTDOWN_MS=10000
LIFECYCLE_BELL_MS=3000
LIFECYCLE_DISPENSING_MS=2000
LIFECYCLE_ARCHIVE_DELAY_MS=2000
